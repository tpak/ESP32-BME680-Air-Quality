{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Temperature",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": ""
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": [
              { "id": "unit", "value": "fahrenheit" },
              { "id": "custom.axisPlacement", "value": "left" },
              { "id": "custom.axisLabel", "value": "Fahrenheit" }
            ]
          },
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [
              { "id": "unit", "value": "celsius" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "custom.axisLabel", "value": "Celsius" }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "expr": "bme680_TempF",
          "legendFormat": "{{location}} (F)",
          "refId": "A"
        },
        {
          "expr": "bme680_Temp",
          "legendFormat": "{{location}} (C)",
          "refId": "B"
        }
      ]
    },
    {
